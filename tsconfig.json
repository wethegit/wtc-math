{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "skipLibCheck": true,
    "declaration": true,
    "declarationDir": "./dist"
  },
  "include": ["src", "vite.config.ts", "vite.site.config.ts"],
  "exclude": ["dist", "dist-site", "node_modules", "demos"],
  "typedocOptions": {
    "out": "documentation",
    "entryPoints": "src/index.ts",
    "exclude": ["dist/*+.ts*"]
  }
}
