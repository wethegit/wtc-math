extends ./_layout

block title
  | wtc-math — Camera CSS Transform

block head
  style.
    .ctrl-label { width: 60px; }

    .quat-box {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-left: 2px solid var(--amber-border);
      border-radius: 0 var(--r) var(--r) 0;
      padding: 6px 10px;
      font-size: var(--fs-sm);
      color: var(--amber);
      line-height: 1.7;
    }

    .code-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--r);
      padding: 9px 11px;
      font-size: var(--fs-sm);
      line-height: 1.75;
      color: var(--text-mid);
      white-space: pre;
      overflow-x: auto;
      flex: 1;
      min-height: 0;
    }

    .viewport-wrap {
      position: relative;
      overflow: hidden;
      background: var(--surface);
    }

    .scene-3d {
      position: absolute;
      top: 50%; left: 50%;
      width: 0; height: 0;
      transform-style: preserve-3d;
    }

    .css-cube {
      position: absolute;
      transform-style: preserve-3d;
    }

    .cube-face {
      position: absolute;
      width: 280px; height: 280px;
      margin: -140px;
      border: 1px solid;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font);
      font-size: var(--fs-md);
      font-weight: 500;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      backface-visibility: visible;
    }

    .cube-face.front  { transform: translateZ(140px);                 background: color-mix(in srgb, var(--green)  4%, transparent); border-color: color-mix(in srgb, var(--green)  22%, transparent); color: color-mix(in srgb, var(--green)  50%, transparent); }
    .cube-face.back   { transform: rotateY(180deg) translateZ(140px); background: color-mix(in srgb, var(--green)  2%, transparent); border-color: color-mix(in srgb, var(--green)  10%, transparent); color: color-mix(in srgb, var(--green)  30%, transparent); }
    .cube-face.right  { transform: rotateY(90deg) translateZ(140px);  background: color-mix(in srgb, var(--purple) 4%, transparent); border-color: color-mix(in srgb, var(--purple) 22%, transparent); color: color-mix(in srgb, var(--purple) 50%, transparent); }
    .cube-face.left   { transform: rotateY(-90deg) translateZ(140px); background: color-mix(in srgb, var(--purple) 2%, transparent); border-color: color-mix(in srgb, var(--purple) 10%, transparent); color: color-mix(in srgb, var(--purple) 30%, transparent); }
    .cube-face.top    { transform: rotateX(90deg) translateZ(140px);  background: color-mix(in srgb, var(--amber)  4%, transparent); border-color: color-mix(in srgb, var(--amber)  22%, transparent); color: color-mix(in srgb, var(--amber)  50%, transparent); }
    .cube-face.bottom { transform: rotateX(-90deg) translateZ(140px); background: color-mix(in srgb, var(--amber)  2%, transparent); border-color: color-mix(in srgb, var(--amber)  10%, transparent); color: color-mix(in srgb, var(--amber)  30%, transparent); }

    #scene-canvas {
      position: absolute;
      top: 0; left: 0;
      pointer-events: none;
    }

    .pt-label {
      position: absolute;
      top: 0; left: 0;
      font-family: var(--font);
      font-size: var(--fs-sm);
      font-weight: 500;
      pointer-events: none;
      white-space: nowrap;
      background: var(--label-bg);
      padding: 1px 5px;
      border-radius: 2px;
      text-shadow: 0 0 6px currentColor;
      transform-origin: top left;
    }

    .pt-label--x { color: var(--red); }
    .pt-label--y { color: var(--green); }
    .pt-label--z { color: var(--purple); }

    .lookat-box {
      background: var(--surface-2);
      border: 1px solid var(--border);
      border-left: 2px solid var(--green-border);
      border-radius: 0 var(--r) var(--r) 0;
      padding: 6px 10px;
      font-size: var(--fs-sm);
      color: var(--green);
      line-height: 1.7;
    }

block header-desc
  p.header-desc
    a(href="./index.html") demos
    span.breadcrumb-sep ›
    span.breadcrumb-current Camera to CSS Transform

block main
  main.demo-main
    aside.demo-controls

      div.ctrl-section
        h3 Orbit (via Quaternion)
        div.ctrl-row
          span.ctrl-label yaw °
          input.ctrl-slider(type="range" id="yaw" min="-180" max="180" step="1" value="30")
          input.ctrl-num(type="number" id="yawn" min="-180" max="180" step="1" value="30")
        div.ctrl-row
          span.ctrl-label pitch °
          input.ctrl-slider(type="range" id="pitch" min="-89" max="89" step="1" value="20")
          input.ctrl-num(type="number" id="pitchn" min="-89" max="89" step="1" value="20")
        div.ctrl-row
          span.ctrl-label radius
          input.ctrl-slider(type="range" id="radius" min="2" max="12" step="0.1" value="5")
          input.ctrl-num(type="number" id="radiusn" min="2" max="12" step="0.1" value="5")
        div.quat-box#quat-box q = { x: 0.000, y: 0.000, z: 0.000, w: 1.000 }

      div.ctrl-section
        h3 Look At Vector
        div.lookat-box#lookat-box forward = { x: 0.000, y: 0.000, z: -1.000 }

      div.ctrl-section.ctrl-section--fill
        h3 Live Code
        pre.code-box#code-box

    div.viewport-wrap#viewport
      div.scene-3d#scene-3d
        div.css-cube
          div.cube-face.front front
          div.cube-face.back back
          div.cube-face.right right
          div.cube-face.left left
          div.cube-face.top top
          div.cube-face.bottom bottom
      canvas#scene-canvas

block footer-links
  a.footer-link(href="./index.html") demos

block footer-right
  span.footer-right Mat4 + Quat to CSS transform

block scripts
  script(type="module" src="./camera.ts")
